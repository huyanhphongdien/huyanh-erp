{
  "deno.enablePaths": [
    "supabase/functions"
  ],
  "deno.lint": true,
  "deno.unstable": [
    "bare-node-builtins",
    "byonm",
    "sloppy-imports",
    "unsafe-proto",
    "webgpu",
    "broadcast-channel",
    "worker-options",
    "cron",
    "kv",
    "ffi",
    "fs",
    "http",
    "net"
  ],
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },

  // Tắt Code Spell Checker — project tiếng Việt, mọi từ bị flag là noise.
  // Nếu muốn check spelling tiếng Anh trong code, mở lại + thêm "vi" vào dictionary.
  "cSpell.enabled": false,
  "cSpell.enabledFileTypes": {
    "markdown": false,
    "plaintext": false
  },
  "cSpell.ignorePaths": [
    "docs/**",
    ".claude/**",
    "memory/**",
    "**/*.md"
  ]
}
