# =============================================================================
# Weighbridge sub-app — Multi-facility env (F2)
# =============================================================================
# 1 codebase, 3 deploys. Mỗi instance đặt 1 giá trị VITE_FACILITY_CODE riêng:
#
#   PD   → Phong Điền (HQ)        → can.huyanhrubber.vn      (mặc định)
#   TL   → Tân Lâm                → can-tl.huyanhrubber.vn
#   LAO  → Lào (Savannakhet)      → can-lao.huyanhrubber.vn
#
# Code phải khớp với cột `facilities.code` trong Supabase.
# Nếu để trống → fallback PD (giữ tương thích version cũ).
# =============================================================================

VITE_FACILITY_CODE=PD

# Supabase config — tất cả 3 instance dùng chung 1 DB
VITE_SUPABASE_URL=https://dygveetaatqllhjusyzz.supabase.co
VITE_SUPABASE_ANON_KEY=
